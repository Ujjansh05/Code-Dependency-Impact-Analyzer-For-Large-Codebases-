# ── TigerGraph ────────────────────────────────────────
TG_HOST=tigergraph
TG_PORT=9000
TG_USERNAME=tigergraph
TG_PASSWORD=tigergraph
TG_GRAPH_NAME=CodeGraph

# ── Ollama / LLaMA ───────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_INFERENCE_MODE=fast
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_BATCH=128
OLLAMA_NUM_THREAD=6
OLLAMA_FAST_NUM_CTX=1024
OLLAMA_FAST_NUM_BATCH=64
OLLAMA_FAST_NUM_THREAD=6
OLLAMA_SLOW_NUM_CTX=3072
OLLAMA_SLOW_NUM_BATCH=128
OLLAMA_SLOW_NUM_THREAD=6
OLLAMA_EXTRACTION_MODE=fast

# ── FastAPI ──────────────────────────────────────────
BACKEND_PORT=8000
DEBUG=true
